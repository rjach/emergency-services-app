PORT=8848
MONGODB_URI=mongodb://127.0.0.1:27017/emergency_services_app
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Optional: comma-separated frontend origins if not on localhost (e.g. https://app.example.com)
# CORS_ORIGINS=

# --- Voice incident assistant (GitHub Models inference) ---
# Create a Personal Access Token at https://github.com/settings/tokens with the **models** scope
# (GitHub → Settings → Developer settings → Fine-grained or classic PAT per GitHub Models docs).
GITHUB_MODELS_PAT=

# OpenAI-compatible inference root (no trailing slash). Requests use POST /chat/completions.
GITHUB_MODELS_INFERENCE_URL=https://models.github.ai/inference

# Catalog model id, e.g. openai/gpt-4o-mini
GITHUB_MODELS_VOICE_MODEL=openai/gpt-4o-mini
